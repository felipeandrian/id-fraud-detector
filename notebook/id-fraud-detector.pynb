      "cell_type": "code",
      "source": [
        "import os\n",
        "from azure.core.credentials import AzureKeyCredential\n",
        "from azure.ai.formrecognizer import DocumentAnalysisClient\n",
        "from google import genai\n",
        "from google.colab import userdata\n",
        "\n",
        "# Recuperando as chaves do cofre (Secrets) do Colab\n",
        "AZURE_ENDPOINT = userdata.get('AZURE_ENDPOINT')\n",
        "AZURE_KEY = userdata.get('AZURE_KEY_ID')\n",
        "GEMINI_KEY = userdata.get('GEMINI_KEY')\n",
        "\n",
        "# Inicializando o cliente do Azure\n",
        "azure_client = DocumentAnalysisClient(\n",
        "    endpoint=AZURE_ENDPOINT,\n",
        "    credential=AzureKeyCredential(AZURE_KEY)\n",
        ")\n",
        "\n",
        "# Inicializando o novo cliente do Gemini\n",
        "gemini_client = genai.Client(api_key=GEMINI_KEY)\n",
        "\n",
        "print(\" Credenciais configuradas com sucesso, em segurança e sem avisos!\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "GUWSW3Gi127W",
        "outputId": "3a9519e9-2e0c-45aa-b30b-a860cf501c67"
      },
      "execution_count": 6,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            " Credenciais configuradas com sucesso, em segurança e sem avisos!\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "from google.colab import files\n",
        "\n",
        "def analisar_documento_local():\n",
        "    print(\" Por favor, faça o upload da imagem do documento (JPG, PNG ou PDF)...\")\n",
        "    uploaded = files.upload()\n",
        "    nome_arquivo = list(uploaded.keys())[0]\n",
        "\n",
        "    print(f\"\\n[+] 1. Enviando o arquivo '{nome_arquivo}' para o Azure...\")\n",
        "\n",
        "    with open(nome_arquivo, \"rb\") as documento:\n",
        "        poller = azure_client.begin_analyze_document(\n",
        "            \"prebuilt-idDocument\", document=documento\n",
        "        )\n",
        "        resultado_azure = poller.result()\n",
        "\n",
        "    # Dicionário para traduzir os campos do Azure para Português\n",
        "    mapa_campos = {\n",
        "        \"FirstName\": \"Nome\",\n",
        "        \"LastName\": \"Sobrenome\",\n",
        "        \"DocumentNumber\": \"Número do Documento\",\n",
        "        \"PersonalNumber\": \"CPF\",\n",
        "        \"DateOfBirth\": \"Data de Nascimento\",\n",
        "        \"DateOfIssue\": \"Data de Emissão\",\n",
        "        \"DateOfExpiration\": \"Data de Expiração\",\n",
        "        \"Sex\": \"Sexo\",\n",
        "        \"Address\": \"Endereço\",\n",
        "        \"CountryRegion\": \"País\",\n",
        "        \"Region\": \"Estado\"\n",
        "    }\n",
        "\n",
        "    dados_extraidos = {}\n",
        "    for idx, doc in enumerate(resultado_azure.documents):\n",
        "        for nome_campo, campo in doc.fields.items():\n",
        "            if campo.value:\n",
        "                # Se o campo existir no mapa, traduz. Se não, usa o nome original.\n",
        "                nome_traduzido = mapa_campos.get(nome_campo, nome_campo)\n",
        "\n",
        "                dados_extraidos[nome_traduzido] = {\n",
        "                    \"valor\": campo.value,\n",
        "                    \"confianca\": campo.confidence\n",
        "                }\n",
        "\n",
        "    print(\"\\n --- DADOS LIDOS DO DOCUMENTO ---\")\n",
        "    for campo, info in dados_extraidos.items():\n",
        "        print(f\"[+] {campo}: {info['valor']} (Confiança: {info['confianca']})\")\n",
        "    print(\"------------------------------------\\n\")\n",
        "\n",
        "    print(\"[+] 2. Dados extraídos! Enviando para o Gemini auditar...\")\n",
        "\n",
        "    # Prompt atualizado com os nomes em português\n",
        "    prompt = f\"\"\"\n",
        "    Você é um auditor especialista em prevenção de fraudes.\n",
        "    Analise os seguintes dados extraídos de um documento de identidade por um sistema de OCR:\n",
        "\n",
        "    {dados_extraidos}\n",
        "\n",
        "    Regras de análise:\n",
        "    1. Verifique a pontuação de confiança (confianca) de cada campo. Se a confiança de campos cruciais (como Nome, Sobrenome, Número do Documento, Data de Nascimento) for menor que 0.85, sinalize como ALTA SUSPEITA de adulteração visual (texto colado por cima ou imagem de baixíssima qualidade).\n",
        "    2. Analise a coerência lógica e temporal (ex: a Data de Expiração não pode ser anterior à Data de Emissão).\n",
        "    3. Retorne o seu veredito exatamente neste formato:\n",
        "       - VEREDITO: [APROVADO, SUSPEITO ou FRAUDE]\n",
        "       - JUSTIFICATIVA: [Explique o motivo em tópicos curtos e diretos]\n",
        "    \"\"\"\n",
        "\n",
        "    try:\n",
        "        resposta_gemini = gemini_client.models.generate_content(\n",
        "            model='gemini-2.5-flash',\n",
        "            contents=prompt\n",
        "        )\n",
        "\n",
        "        print(\"\\n\" + \"=\"*30)\n",
        "        print(\" [+] RESULTADO DA AUDITORIA \")\n",
        "        print(\"=\"*30)\n",
        "        print(resposta_gemini.text)\n",
        "\n",
        "    except Exception as e:\n",
        "        print(\"\\n[+] Ops! Erro ao consultar o Gemini.\")\n",
        "        print(f\"Detalhe: {e}\")\n",
        "\n",
        "# Executando a nova função\n",
        "analisar_documento_local()"
      ],
      "metadata": {
